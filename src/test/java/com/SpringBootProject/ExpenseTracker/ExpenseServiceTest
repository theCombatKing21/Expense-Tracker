package com.SpringBootProject.ExpenseTracker.service;

import com.SpringBootProject.ExpenseTracker.dto.CategorySummaryResponse;
import com.SpringBootProject.ExpenseTracker.dto.ExpenseRequest;
import com.SpringBootProject.ExpenseTracker.dto.ExpenseResponse;
import com.SpringBootProject.ExpenseTracker.dto.MonthlySummaryResponse;
import com.SpringBootProject.ExpenseTracker.entity.Category;
import com.SpringBootProject.ExpenseTracker.entity.Expense;
import com.SpringBootProject.ExpenseTracker.entity.User;
import com.SpringBootProject.ExpenseTracker.exception.ResourceNotFoundException;
import com.SpringBootProject.ExpenseTracker.repository.CategoryRepository;
import com.SpringBootProject.ExpenseTracker.repository.ExpenseRepository;
import com.SpringBootProject.ExpenseTracker.repository.UserRepository;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import org.springframework.data.domain.Page;
import org.springframework.data.domain.PageImpl;
import org.springframework.data.domain.PageRequest;
import org.springframework.data.domain.Pageable;

import java.math.BigDecimal;
import java.time.LocalDate;
import java.util.List;
import java.util.Optional;

import static org.assertj.core.api.Assertions.assertThat;
import static org.assertj.core.api.Assertions.assertThatThrownBy;
import static org.mockito.ArgumentMatchers.any;
import static org.mockito.ArgumentMatchers.anyLong;
import static org.mockito.Mockito.*;

@ExtendWith(MockitoExtension.class)
class ExpenseServiceTest {

    // ExpenseService depends on THREE repositories — we mock all three.
    // @InjectMocks will inject all three into the real ExpenseService instance.
    @Mock
    private ExpenseRepository expenseRepository;

    @Mock
    private UserRepository userRepository;

    @Mock
    private CategoryRepository categoryRepository;

    @InjectMocks
    private ExpenseService expenseService;

    // ---- Shared test data, rebuilt before each test ----
    private User testUser;
    private Category testCategory;
    private Expense testExpense;
    private ExpenseRequest validRequest;

    @BeforeEach
    void setUp() {
        testUser = User.builder()
                .id(1L)
                .name("Arjun Sharma")
                .email("arjun@example.com")
                .password("secret")
                .build();

        testCategory = Category.builder()
                .id(1L)
                .name("Food")
                .description("All food expenses")
                .build();

        // This is what the repository returns AFTER the expense is saved.
        // It has an id (auto-generated by DB) and full User/Category objects attached.
        testExpense = Expense.builder()
                .id(1L)
                .description("Lunch at canteen")
                .amount(new BigDecimal("150.00"))
                .date(LocalDate.of(2025, 3, 10))
                .notes("Had thali")
                .user(testUser)
                .category(testCategory)
                .build();

        // This is what the client sends. Notice: only IDs for user and category,
        // not full objects — just like the real API contract.
        validRequest = ExpenseRequest.builder()
                .description("Lunch at canteen")
                .amount(new BigDecimal("150.00"))
                .date(LocalDate.of(2025, 3, 10))
                .notes("Had thali")
                .userId(1L)
                .categoryId(1L)
                .build();
    }

    // ============================================================
    // TEST 1: Create expense — happy path
    // ============================================================
    @Test
    @DisplayName("Should create expense and return response with resolved names")
    void createExpense_whenUserAndCategoryExist_shouldReturnExpenseResponse() {

        // ARRANGE: The service does three repository calls in createExpense():
        //   1. userRepository.findById(userId)
        //   2. categoryRepository.findById(categoryId)
        //   3. expenseRepository.save(expense)
        // We must stub all three — if any returns unexpected data, the service logic changes.
        when(userRepository.findById(1L)).thenReturn(Optional.of(testUser));
        when(categoryRepository.findById(1L)).thenReturn(Optional.of(testCategory));
        when(expenseRepository.save(any(Expense.class))).thenReturn(testExpense);

        // ACT
        ExpenseResponse response = expenseService.createExpense(validRequest);

        // ASSERT: Check the DTO mapping resolved IDs into names correctly.
        // This is the key value of ExpenseResponse — it gives back names, not just IDs.
        assertThat(response).isNotNull();
        assertThat(response.getId()).isEqualTo(1L);
        assertThat(response.getDescription()).isEqualTo("Lunch at canteen");
        assertThat(response.getAmount()).isEqualByComparingTo(new BigDecimal("150.00"));

        // These two assertions are the most important — they verify that
        // the service correctly resolved userId → userName, categoryId → categoryName.
        assertThat(response.getUserName()).isEqualTo("Arjun Sharma");
        assertThat(response.getCategoryName()).isEqualTo("Food");

        // Note: assertThat(bd1).isEqualByComparingTo(bd2) is used instead of isEqualTo()
        // for BigDecimal because isEqualTo() also checks scale:
        // new BigDecimal("150.00").equals(new BigDecimal("150.0")) → FALSE (different scale)
        // isEqualByComparingTo() uses compareTo() which only checks mathematical value:
        // new BigDecimal("150.00").compareTo(new BigDecimal("150.0")) → 0 (equal) ✓

        // VERIFY all three repository methods were called exactly once
        verify(userRepository, times(1)).findById(1L);
        verify(categoryRepository, times(1)).findById(1L);
        verify(expenseRepository, times(1)).save(any(Expense.class));
    }

    // ============================================================
    // TEST 2: Create expense — user not found
    // ============================================================
    @Test
    @DisplayName("Should throw ResourceNotFoundException when userId does not exist")
    void createExpense_whenUserNotFound_shouldThrowResourceNotFoundException() {

        // ARRANGE: Simulate that userId 1 doesn't exist
        when(userRepository.findById(1L)).thenReturn(Optional.empty());

        // ACT + ASSERT
        assertThatThrownBy(() -> expenseService.createExpense(validRequest))
                .isInstanceOf(ResourceNotFoundException.class)
                .hasMessageContaining("1"); // Message should mention the missing userId

        // VERIFY: Because the user lookup failed, we must NEVER reach the save() call.
        // This tests that the service fails fast and doesn't partially execute.
        verify(expenseRepository, never()).save(any());

        // And since user wasn't found, we shouldn't even look up the category
        verify(categoryRepository, never()).findById(anyLong());
    }

    // ============================================================
    // TEST 3: Create expense — category not found
    // ============================================================
    @Test
    @DisplayName("Should throw ResourceNotFoundException when categoryId does not exist")
    void createExpense_whenCategoryNotFound_shouldThrowResourceNotFoundException() {

        // User EXISTS, but category does NOT
        when(userRepository.findById(1L)).thenReturn(Optional.of(testUser));
        when(categoryRepository.findById(1L)).thenReturn(Optional.empty());

        assertThatThrownBy(() -> expenseService.createExpense(validRequest))
                .isInstanceOf(ResourceNotFoundException.class)
                .hasMessageContaining("1");

        // User was found (1 call), but save should still never happen
        verify(userRepository, times(1)).findById(1L);
        verify(expenseRepository, never()).save(any());
    }

    // ============================================================
    // TEST 4: Get single expense — found
    // ============================================================
    @Test
    @DisplayName("Should return expense response when expense ID exists")
    void getExpenseById_whenExpenseExists_shouldReturnExpenseResponse() {

        when(expenseRepository.findById(1L)).thenReturn(Optional.of(testExpense));

        ExpenseResponse response = expenseService.getExpenseById(1L);

        assertThat(response.getId()).isEqualTo(1L);
        assertThat(response.getDescription()).isEqualTo("Lunch at canteen");
        assertThat(response.getCategoryName()).isEqualTo("Food");

        verify(expenseRepository, times(1)).findById(1L);
    }

    // ============================================================
    // TEST 5: Get single expense — not found
    // ============================================================
    @Test
    @DisplayName("Should throw ResourceNotFoundException when expense ID does not exist")
    void getExpenseById_whenExpenseNotFound_shouldThrowResourceNotFoundException() {

        when(expenseRepository.findById(99L)).thenReturn(Optional.empty());

        assertThatThrownBy(() -> expenseService.getExpenseById(99L))
                .isInstanceOf(ResourceNotFoundException.class)
                .hasMessageContaining("99");
    }

    // ============================================================
    // TEST 6: Pagination — get expenses by user
    // ============================================================
    @Test
    @DisplayName("Should return paginated expenses for a valid user")
    void getExpensesByUser_whenUserExists_shouldReturnPagedResults() {

        // ARRANGE: Pageable is constructed by the caller (controller in real life,
        // us in the test). We pass page=0, size=10.
        Pageable pageable = PageRequest.of(0, 10);

        // PageImpl is Spring's concrete implementation of the Page interface.
        // We create a page that contains just our one testExpense.
        // PageImpl(content, pageable, totalElements):
        //   content       = the items on this page
        //   pageable      = the page request
        //   totalElements = total count across ALL pages (used to calculate totalPages)
        Page<Expense> mockPage = new PageImpl<>(List.of(testExpense), pageable, 1);

        when(userRepository.existsById(1L)).thenReturn(true);
        when(expenseRepository.findByUserId(1L, pageable)).thenReturn(mockPage);

        // ACT
        Page<ExpenseResponse> result = expenseService.getExpensesByUser(1L, pageable);

        // ASSERT on the Page metadata AND the content
        assertThat(result).isNotNull();
        assertThat(result.getTotalElements()).isEqualTo(1);
        assertThat(result.getContent()).hasSize(1);
        assertThat(result.getContent().get(0).getDescription()).isEqualTo("Lunch at canteen");

        verify(expenseRepository, times(1)).findByUserId(1L, pageable);
    }

    // ============================================================
    // TEST 7: Delete expense — exists
    // ============================================================
    @Test
    @DisplayName("Should delete expense when ID exists")
    void deleteExpense_whenExpenseExists_shouldCallDeleteById() {

        when(expenseRepository.existsById(1L)).thenReturn(true);

        // deleteExpense returns void — nothing to capture.
        expenseService.deleteExpense(1L);

        // The only way to verify void methods is through verify().
        verify(expenseRepository, times(1)).existsById(1L);
        verify(expenseRepository, times(1)).deleteById(1L);
    }

    // ============================================================
    // TEST 8: Delete expense — does not exist
    // ============================================================
    @Test
    @DisplayName("Should throw ResourceNotFoundException when deleting non-existent expense")
    void deleteExpense_whenExpenseNotFound_shouldThrow() {

        when(expenseRepository.existsById(99L)).thenReturn(false);

        assertThatThrownBy(() -> expenseService.deleteExpense(99L))
                .isInstanceOf(ResourceNotFoundException.class);

        verify(expenseRepository, never()).deleteById(anyLong());
    }

    // ============================================================
    // TEST 9: Analytics — spending by category
    // ============================================================
    @Test
    @DisplayName("Should return spending grouped by category for a valid user")
    void getSpendingByCategory_whenUserExists_shouldReturnSummaryList() {

        // The JPQL query returns List<Object[]>.
        // Each Object[] is: [0] = categoryName (String), [1] = totalAmount (BigDecimal).
        // We simulate two categories with their totals.
        Object[] foodRow      = new Object[]{"Food",      new BigDecimal("1350.00")};
        Object[] transportRow = new Object[]{"Transport", new BigDecimal("450.50")};

        when(userRepository.existsById(1L)).thenReturn(true);
        when(expenseRepository.findSpendingByCategory(1L))
                .thenReturn(List.of(foodRow, transportRow));

        // ACT
        List<CategorySummaryResponse> result = expenseService.getSpendingByCategory(1L);

        // ASSERT
        assertThat(result).hasSize(2);
        assertThat(result.get(0).getCategoryName()).isEqualTo("Food");
        assertThat(result.get(0).getTotalAmount()).isEqualByComparingTo(new BigDecimal("1350.00"));
        assertThat(result.get(1).getCategoryName()).isEqualTo("Transport");

        verify(expenseRepository, times(1)).findSpendingByCategory(1L);
    }

    // ============================================================
    // TEST 10: Analytics — monthly summary
    // ============================================================
    @Test
    @DisplayName("Should return correct monthly total and expense count")
    void getMonthlySummary_whenUserExists_shouldReturnSummary() {

        // March 2025 date range that the service will compute internally:
        // startDate = 2025-03-01, endDate = 2025-03-31
        LocalDate start = LocalDate.of(2025, 3, 1);
        LocalDate end   = LocalDate.of(2025, 3, 31);

        // Expenses within that range — the service calls findByUserIdAndDateBetween
        // to count them, and findTotalSpendingBetweenDates for the BigDecimal total.
        Expense expense2 = Expense.builder()
                .id(2L)
                .description("Uber to airport")
                .amount(new BigDecimal("450.50"))
                .date(LocalDate.of(2025, 3, 12))
                .user(testUser)
                .category(testCategory)
                .build();

        when(userRepository.existsById(1L)).thenReturn(true);
        when(expenseRepository.findTotalSpendingBetweenDates(1L, start, end))
                .thenReturn(new BigDecimal("600.50")); // 150 + 450.50
        when(expenseRepository.findByUserIdAndDateBetween(1L, start, end))
                .thenReturn(List.of(testExpense, expense2));

        // ACT
        MonthlySummaryResponse result = expenseService.getMonthlySummary(1L, 2025, 3);

        // ASSERT
        assertThat(result.getYear()).isEqualTo(2025);
        assertThat(result.getMonth()).isEqualTo(3);
        assertThat(result.getTotalSpending()).isEqualByComparingTo(new BigDecimal("600.50"));
        assertThat(result.getExpenseCount()).isEqualTo(2);
    }

    // ============================================================
    // TEST 11: Analytics — monthly summary for a month with no expenses
    // ============================================================
    @Test
    @DisplayName("Should return zero total and zero count for a month with no expenses")
    void getMonthlySummary_whenNoExpensesInMonth_shouldReturnZeroes() {

        LocalDate start = LocalDate.of(2025, 4, 1);
        LocalDate end   = LocalDate.of(2025, 4, 30);

        when(userRepository.existsById(1L)).thenReturn(true);
        // COALESCE in the JPQL means the repository never returns null — it returns ZERO.
        // This test verifies that our zero-handling assumption is correct end-to-end.
        when(expenseRepository.findTotalSpendingBetweenDates(1L, start, end))
                .thenReturn(BigDecimal.ZERO);
        when(expenseRepository.findByUserIdAndDateBetween(1L, start, end))
                .thenReturn(List.of()); // empty list

        MonthlySummaryResponse result = expenseService.getMonthlySummary(1L, 2025, 4);

        assertThat(result.getTotalSpending()).isEqualByComparingTo(BigDecimal.ZERO);
        assertThat(result.getExpenseCount()).isEqualTo(0);
    }
}
