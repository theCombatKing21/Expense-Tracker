package com.SpringBootProject.ExpenseTracker.service;

import com.SpringBootProject.ExpenseTracker.dto.UserRequest;
import com.SpringBootProject.ExpenseTracker.dto.UserResponse;
import com.SpringBootProject.ExpenseTracker.entity.User;
import com.SpringBootProject.ExpenseTracker.exception.DuplicateResourceException;
import com.SpringBootProject.ExpenseTracker.exception.ResourceNotFoundException;
import com.SpringBootProject.ExpenseTracker.repository.UserRepository;
import org.junit.jupiter.api.*;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;

import java.util.List;
import java.util.Optional;

import static org.assertj.core.api.Assertions.assertThat;
import static org.assertj.core.api.Assertions.assertThatThrownBy;
import static org.mockito.ArgumentMatchers.any;
import static org.mockito.ArgumentMatchers.anyString;
import static org.mockito.Mockito.*;

// ============================================================
// @ExtendWith(MockitoExtension.class)
// ============================================================
// This is the MOST IMPORTANT annotation on the class.
// It activates Mockito's JUnit 5 integration.
// Without it, @Mock and @InjectMocks are ignored — your mocks are null
// and you get NullPointerExceptions when the test runs.
//
// In JUnit 4 (older projects), the equivalent was @RunWith(MockitoJUnitRunner.class).
// JUnit 5 replaced @RunWith with @ExtendWith — a common interview question.
@ExtendWith(MockitoExtension.class)
class UserServiceTest {

    // ============================================================
    // @Mock
    // ============================================================
    // Creates a FAKE UserRepository managed by Mockito.
    // This fake does NOT connect to PostgreSQL. It does nothing by default.
    // You control exactly what it returns via when(...).thenReturn(...).
    //
    // Why mock the repository and not the service?
    // Because UserService IS what we're testing. We want to test its logic
    // in isolation — without the database, without Hibernate, without Spring.
    // The repository is a dependency we want to fake.
    @Mock
    private UserRepository userRepository;

    // ============================================================
    // @InjectMocks
    // ============================================================
    // Creates a REAL instance of UserService.
    // Mockito looks at UserService's constructor (generated by @RequiredArgsConstructor)
    // and passes the @Mock userRepository into it automatically.
    // So userService.userRepository IS the fake above — not a real DB-connected one.
    //
    // Think of it as: "Make a real car, but give it a simulator engine instead of a real one."
    @InjectMocks
    private UserService userService;

    // ============================================================
    // Test data — shared across multiple tests
    // ============================================================
    private UserRequest validRequest;
    private User savedUser;

    // ============================================================
    // @BeforeEach
    // ============================================================
    // This method runs BEFORE EVERY @Test method in this class.
    // Use it to reset and rebuild shared test data so each test
    // starts with a clean, predictable state — tests must never
    // depend on each other's side effects.
    //
    // Naming convention: setUp() is the most common name, but anything works.
    @BeforeEach
    void setUp() {
        // This is the request object a client would send to create a user.
        // We build it once here so every test can use it without repeating this code.
        validRequest = UserRequest.builder()
                .name("Arjun Sharma")
                .email("arjun@example.com")
                .password("secret123")
                .build();

        // This is the User entity that the repository would return AFTER saving.
        // Notice it has an id (1L) — because after saving, the DB assigns the ID.
        // The request DTO doesn't have an ID; the saved entity does.
        savedUser = User.builder()
                .id(1L)
                .name("Arjun Sharma")
                .email("arjun@example.com")
                .password("secret123")
                .build();
    }

    // ============================================================
    // TEST 1: Happy path — successfully creating a user
    // ============================================================
    // Naming convention: methodName_condition_expectedResult
    // This makes test failures self-describing in reports.
    @Test
    @DisplayName("Should create user and return response without password when email is unique")
    void createUser_whenEmailIsUnique_shouldReturnUserResponse() {

        // ---- ARRANGE ----
        // "Arrange" means: set up the conditions (stubs) for this specific scenario.
        //
        // Stub 1: When the service asks "does this email exist?", say NO.
        // This simulates the happy path where the email is brand new.
        when(userRepository.existsByEmail("arjun@example.com")).thenReturn(false);

        // Stub 2: When the service calls save() with any User object, return our savedUser.
        // We use any(User.class) because the service builds a new User object internally —
        // we can't predict its exact reference, but we know it will be a User instance.
        when(userRepository.save(any(User.class))).thenReturn(savedUser);

        // ---- ACT ----
        // "Act" means: call the actual method you're testing.
        UserResponse response = userService.createUser(validRequest);

        // ---- ASSERT ----
        // "Assert" means: verify the output is what you expected.
        //
        // AssertJ (assertThat) is preferred over JUnit's Assertions.assertEquals()
        // because it reads like English and gives better failure messages.
        // "assertThat(actual).isEqualTo(expected)" vs "assertEquals(expected, actual)"
        // Note the reversed argument order in JUnit — a common source of confusion.
        assertThat(response).isNotNull();
        assertThat(response.getId()).isEqualTo(1L);
        assertThat(response.getName()).isEqualTo("Arjun Sharma");
        assertThat(response.getEmail()).isEqualTo("arjun@example.com");

        // This is the MOST IMPORTANT assertion in this test:
        // The UserResponse DTO intentionally has no password field.
        // We're verifying the security boundary — that the service never leaks the password.
        // If someone accidentally adds 'password' to UserResponse, this test documents that intent.
        // (In practice you'd add a 'getPassword()' method to UserResponse to test this,
        //  but since we intentionally omit it, we verify via the DTO structure itself.)

        // ---- VERIFY ----
        // Verify that save() was called exactly once. If the service called it 0 or 2 times,
        // this assertion fails — catching accidental duplicate saves or skipped saves.
        verify(userRepository, times(1)).save(any(User.class));

        // Verify existsByEmail was called with the correct email — not some other string.
        verify(userRepository, times(1)).existsByEmail("arjun@example.com");
    }

    // ============================================================
    // TEST 2: Duplicate email — should throw, never save
    // ============================================================
    @Test
    @DisplayName("Should throw DuplicateResourceException when email already exists")
    void createUser_whenEmailAlreadyExists_shouldThrowDuplicateResourceException() {

        // ARRANGE: Simulate that this email is already in the database.
        when(userRepository.existsByEmail("arjun@example.com")).thenReturn(true);

        // ACT + ASSERT (combined using AssertJ's assertThatThrownBy):
        // This is the cleanest way to test that an exception is thrown.
        // The lambda inside is the code that SHOULD throw — if it doesn't throw,
        // the test fails. If it throws a DIFFERENT exception, the test fails.
        assertThatThrownBy(() -> userService.createUser(validRequest))
                .isInstanceOf(DuplicateResourceException.class)
                // Also verify the message content — this confirms the error message
                // is informative enough for the client to understand what went wrong.
                .hasMessageContaining("arjun@example.com");

        // VERIFY: The critical check here is that save() was NEVER called.
        // When the service detects a duplicate, it must throw BEFORE calling save().
        // If save() was called, data integrity is compromised.
        // never() is shorthand for times(0).
        verify(userRepository, never()).save(any(User.class));
    }

    // ============================================================
    // TEST 3: Get user by ID — found
    // ============================================================
    @Test
    @DisplayName("Should return user response when user ID exists")
    void getUserById_whenUserExists_shouldReturnUserResponse() {

        // ARRANGE: findById returns Optional.of(savedUser) — simulating a DB hit.
        // Optional.of() wraps a non-null value. Optional.empty() simulates "not found".
        when(userRepository.findById(1L)).thenReturn(Optional.of(savedUser));

        // ACT
        UserResponse response = userService.getUserById(1L);

        // ASSERT
        assertThat(response.getId()).isEqualTo(1L);
        assertThat(response.getName()).isEqualTo("Arjun Sharma");

        // Verify the repository was queried with the correct ID
        verify(userRepository, times(1)).findById(1L);
    }

    // ============================================================
    // TEST 4: Get user by ID — not found
    // ============================================================
    @Test
    @DisplayName("Should throw ResourceNotFoundException when user ID does not exist")
    void getUserById_whenUserDoesNotExist_shouldThrowResourceNotFoundException() {

        // ARRANGE: Return Optional.empty() — simulates "no row found in DB for this ID".
        // The service calls .orElseThrow() on this Optional, which triggers our exception.
        when(userRepository.findById(99L)).thenReturn(Optional.empty());

        // ACT + ASSERT
        assertThatThrownBy(() -> userService.getUserById(99L))
                .isInstanceOf(ResourceNotFoundException.class)
                .hasMessageContaining("99"); // The message should mention the ID that was missing

        // No save should ever happen on a GET call — defensive check.
        verify(userRepository, never()).save(any());
    }

    // ============================================================
    // TEST 5: Get all users
    // ============================================================
    @Test
    @DisplayName("Should return list of all users mapped to response DTOs")
    void getAllUsers_shouldReturnListOfUserResponses() {

        // Build a second user for a more realistic list
        User secondUser = User.builder()
                .id(2L)
                .name("Priya Mehta")
                .email("priya@example.com")
                .password("pass456")
                .build();

        // ARRANGE: findAll() returns both users
        when(userRepository.findAll()).thenReturn(List.of(savedUser, secondUser));

        // ACT
        List<UserResponse> responses = userService.getAllUsers();

        // ASSERT
        assertThat(responses).isNotNull();
        assertThat(responses).hasSize(2); // Exactly 2 users returned

        // Check that the mapping preserved the data correctly for each user
        assertThat(responses.get(0).getName()).isEqualTo("Arjun Sharma");
        assertThat(responses.get(1).getName()).isEqualTo("Priya Mehta");

        verify(userRepository, times(1)).findAll();
    }

    // ============================================================
    // TEST 6: Delete user — exists
    // ============================================================
    @Test
    @DisplayName("Should delete user when ID exists")
    void deleteUser_whenUserExists_shouldCallDeleteById() {

        // ARRANGE: existsById returns true — user is in the DB
        when(userRepository.existsById(1L)).thenReturn(true);

        // deleteById returns void, so there's nothing to stub —
        // Mockito's default for void methods is "do nothing", which is exactly right here.

        // ACT: deleteUser returns void, so no return value to capture
        userService.deleteUser(1L);

        // ASSERT via VERIFY:
        // Since the method returns void, we can't assert on a return value.
        // Instead, we verify the right repository methods were called.
        verify(userRepository, times(1)).existsById(1L);
        verify(userRepository, times(1)).deleteById(1L);
    }

    // ============================================================
    // TEST 7: Delete user — does not exist
    // ============================================================
    @Test
    @DisplayName("Should throw ResourceNotFoundException when deleting non-existent user")
    void deleteUser_whenUserDoesNotExist_shouldThrowResourceNotFoundException() {

        when(userRepository.existsById(99L)).thenReturn(false);

        assertThatThrownBy(() -> userService.deleteUser(99L))
                .isInstanceOf(ResourceNotFoundException.class);

        // deleteById must NEVER be called when the user doesn't exist
        verify(userRepository, never()).deleteById(anyLong());
    }

    // ============================================================
    // TEST 8: Update user — email unchanged (no duplicate check needed)
    // ============================================================
    @Test
    @DisplayName("Should update user successfully when email is unchanged")
    void updateUser_whenEmailUnchanged_shouldUpdateAndReturn() {

        // ARRANGE
        when(userRepository.findById(1L)).thenReturn(Optional.of(savedUser));
        // The request has the SAME email as the existing user — no duplicate check triggered
        when(userRepository.save(any(User.class))).thenReturn(savedUser);

        UserRequest updateRequest = UserRequest.builder()
                .name("Arjun Kumar") // name changed
                .email("arjun@example.com") // email same
                .password("newpassword")
                .build();

        // ACT
        UserResponse response = userService.updateUser(1L, updateRequest);

        // ASSERT
        assertThat(response).isNotNull();
        // existsByEmail should NOT be called when the email hasn't changed.
        // The service has an if(!existing.getEmail().equals(...)) guard.
        verify(userRepository, never()).existsByEmail(anyString());
        verify(userRepository, times(1)).save(any(User.class));
    }
}
